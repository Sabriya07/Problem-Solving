class Solution {
    public void merge(int[] nums1, int m, int[] nums2, int n) {
        int s = m+n;
        m--;
        n--;
        for(int i = s-1; i >= 0 ; i--){
            if(n<0) break;
            if(n >= 0 && m >= 0 &&  nums1[m] < nums2[n] ) nums1[i] = nums2[n--];
            else if ( n >= 0 && m >= 0 && nums1[m]> nums2[n] ) nums1[i] = nums1[m--];
            else nums1[i] = nums2[n--];
        }
        System.out.print(Arrays.toString(nums1));
    }
}
